{
  "name": "skyler-website-personal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "blog:generate": "node scripts/generate-blog-sources.mjs",
    "dev": "bun run blog:generate && next dev",
    "build": "bun run blog:generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "capture:work": "node scripts/capture-work-sites.mjs",
    "build:cloudflare": "bun run blog:generate && opennextjs-cloudflare build",
    "preview": "bun run blog:generate && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "bun run blog:generate && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.24.0",
    "mdast-util-directive": "^3.1.0",
    "next": "16.2.10",
    "next-intl": "^4.13.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@shikijs/rehype": "^4.3.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "playwright": "^1.61.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.110.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
